#!/usr/bin/env bash
set -euo pipefail

lock_file="/run/ansible-pull.lock"
log_file="{{ desktop_pull_log_dir }}/ansible-pull.log"
dest="{{ desktop_pull_destination }}"

mkdir -p "$(dirname "${lock_file}")" "{{ desktop_pull_log_dir }}"

exec 9>"${lock_file}"
if ! flock -n 9; then
  echo "$(date --iso-8601=seconds) ansible-pull already running, skipping." >> "${log_file}"
  exit 0
fi

{
  echo "===== $(date --iso-8601=seconds) ansible-pull start ====="
  /usr/bin/ansible-pull \
    -U "{{ desktop_pull_repo_url }}" \
    -C "{{ desktop_pull_repo_branch }}" \
    -d "${dest}" \
    -i "localhost," \
    -c local \
    {{ desktop_pull_extra_args }} \
    "{{ desktop_pull_playbook }}"
  rc=$?
  echo "===== $(date --iso-8601=seconds) ansible-pull end rc=${rc} ====="
  exit "${rc}"
} >> "${log_file}" 2>&1
